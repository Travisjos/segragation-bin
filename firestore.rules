rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "travisjosh3335@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity Validations
    function isValidBin(data) {
      return data.keys().hasAll(['id', 'name', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.status in ['online', 'offline', 'full', 'maintenance'];
    }

    function isValidLog(data) {
      return data.keys().hasAll(['binId', 'type', 'timestamp']) &&
             data.binId is string &&
             data.type in ['degradable', 'non_degradable'] &&
             data.timestamp == request.time;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'staff', 'resident'];
    }

    // 4. Match Blocks
    match /bins/{binId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidBin(incoming());
      allow update: if (isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['levels', 'lastUpdated']))) 
                    && isValidBin(incoming());
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidLog(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                    (incoming().role == 'resident' || (incoming().role == 'admin' && request.auth.token.email == "travisjosh3335@gmail.com")) && 
                    isValidUser(incoming());
      allow update: if (isOwner(userId) && incoming().role == existing().role && isValidUser(incoming())) || isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System defined
    }
  }
}
